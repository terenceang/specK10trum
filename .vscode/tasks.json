{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile specK10trum",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\platformio.exe",
      "args": [
        "run",
        "--environment",
        "unihiker_k10"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [
        "$platformio"
      ]
    }
  ]
}
